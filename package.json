{
  "name": "variable-name-assistant",
  "version": "1.0.0",
  "type": "module",
  "description": "变量命名助手 - 中文前端开发者变量命名工具",
  "scripts": {
    "start": "vite build && bun run copy:icons && electrobun dev",
    "dev": "bun run copy:icons && electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary",
    "copy:icons": "bun run scripts/copy-icons.ts",
    "generate:icons": "bun run scripts/generate-icons.ts"
  },
  "dependencies": {
    "electrobun": "1.18.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
